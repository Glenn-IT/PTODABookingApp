## 5. Login Activity Implementation

```kotlin
package com.example.ptoda.ui.auth

import android.content.Intent
import android.os.Bundle
import android.widget.Button
import android.widget.EditText
import android.widget.RadioGroup
import android.widget.Toast
import androidx.appcompat.app.AppCompatActivity
import com.example.ptoda.R
import com.example.ptoda.models.LoginRequest
import com.example.ptoda.network.RetrofitClient
import com.example.ptoda.ui.driver.DriverDashboardActivity
import com.example.ptoda.ui.driver.DriverVerificationActivity
import com.example.ptoda.ui.passenger.PassengerDashboardActivity
import com.example.ptoda.utils.PreferenceManager
import retrofit2.Call
import retrofit2.Callback
import retrofit2.Response

class LoginActivity : AppCompatActivity() {

    private lateinit var emailEditText: EditText
    private lateinit var passwordEditText: EditText
    private lateinit var userTypeRadioGroup: RadioGroup
    private lateinit var loginButton: Button

    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        setContentView(R.layout.activity_login)

        // Initialize views
        emailEditText = findViewById(R.id.email_input)
        passwordEditText = findViewById(R.id.password_input)
        userTypeRadioGroup = findViewById(R.id.user_type_radio_group)
        loginButton = findViewById(R.id.login_button)

        // Set default to Driver
        userTypeRadioGroup.check(R.id.radio_driver)

        loginButton.setOnClickListener {
            performLogin()
        }
    }

    private fun performLogin() {
        val email = emailEditText.text.toString().trim()
        val password = passwordEditText.text.toString().trim()

        // Validate input
        if (email.isEmpty() || password.isEmpty()) {
            Toast.makeText(this, "Please fill all fields", Toast.LENGTH_SHORT).show()
            return
        }

        // Get selected user type
        val userType = when (userTypeRadioGroup.checkedRadioButtonId) {
            R.id.radio_driver -> "driver"
            R.id.radio_passenger -> "passenger"
            else -> return
        }

        // Create request
        val loginRequest = LoginRequest(
            email = email,
            password = password,
            user_type = userType
        )

        // Show loading state
        loginButton.isEnabled = false
        loginButton.text = "Logging in..."

        // Make API call
        val apiService = RetrofitClient.getApiService()
        apiService.login(loginRequest).enqueue(object : Callback<com.example.ptoda.models.AuthResponse> {
            override fun onResponse(
                call: Call<com.example.ptoda.models.AuthResponse>,
                response: Response<com.example.ptoda.models.AuthResponse>
            ) {
                loginButton.isEnabled = true
                loginButton.text = "Login"

                if (response.isSuccessful) {
                    val authResponse = response.body()
                    if (authResponse != null && authResponse.status == "success") {

                        // Save auth data
                        authResponse.token?.let { PreferenceManager.saveToken(it) }
                        PreferenceManager.saveUserData(
                            authResponse.user.id,
                            authResponse.user.name,
                            authResponse.user.email,
                            authResponse.user_type,
                            authResponse.is_verified
                        )

                        Toast.makeText(this@LoginActivity, "Login successful", Toast.LENGTH_SHORT).show()

                        // Navigate based on user type and verification status
                        when {
                            authResponse.user_type == "driver" && !authResponse.is_verified -> {
                                // Unverified driver - show verification activity
                                startActivity(Intent(this@LoginActivity, DriverVerificationActivity::class.java))
                            }
                            authResponse.user_type == "driver" -> {
                                // Verified driver - show dashboard
                                startActivity(Intent(this@LoginActivity, DriverDashboardActivity::class.java))
                            }
                            authResponse.user_type == "passenger" -> {
                                // Passenger - show passenger dashboard
                                startActivity(Intent(this@LoginActivity, PassengerDashboardActivity::class.java))
                            }
                        }

                        finish()
                    }
                } else {
                    val errorBody = response.errorBody()?.string()
                    Toast.makeText(
                        this@LoginActivity,
                        "Login failed: $errorBody",
                        Toast.LENGTH_LONG
                    ).show()
                }
            }

            override fun onFailure(call: Call<com.example.ptoda.models.AuthResponse>, t: Throwable) {
                loginButton.isEnabled = true
                loginButton.text = "Login"
                Toast.makeText(
                    this@LoginActivity,
                    "Error: ${t.message}",
                    Toast.LENGTH_LONG
                ).show()
            }
        })
    }
}
