## 7. Driver Verification Activity

```kotlin
package com.example.ptoda.ui.driver

import android.content.Intent
import android.net.Uri
import android.os.Bundle
import android.widget.Button
import android.widget.EditText
import android.widget.ImageView
import android.widget.Toast
import androidx.appcompat.app.AppCompatActivity
import androidx.activity.result.contract.ActivityResultContracts
import com.example.ptoda.R
import com.example.ptoda.network.RetrofitClient
import com.example.ptoda.utils.PreferenceManager
import okhttp3.MediaType.Companion.toMediaTypeOrNull
import okhttp3.MultipartBody
import okhttp3.RequestBody.Companion.asRequestBody
import okhttp3.RequestBody.Companion.toRequestBody
import retrofit2.Call
import retrofit2.Callback
import retrofit2.Response
import java.io.File

class DriverVerificationActivity : AppCompatActivity() {

    private lateinit var licenseNumberEditText: EditText
    private lateinit var vehicleTypeEditText: EditText
    private lateinit var vehiclePlateEditText: EditText
    private lateinit var vehicleModelEditText: EditText
    private lateinit var vehicleColorEditText: EditText
    private lateinit var licenseImageView: ImageView
    private lateinit var vehicleImageView: ImageView
    private lateinit var submitButton: Button

    private var licenseImageUri: Uri? = null
    private var vehicleImageUri: Uri? = null

    private val licenseImageLauncher = registerForActivityResult(
        ActivityResultContracts.GetContent()
    ) { uri ->
        if (uri != null) {
            licenseImageUri = uri
            licenseImageView.setImageURI(uri)
        }
    }

    private val vehicleImageLauncher = registerForActivityResult(
        ActivityResultContracts.GetContent()
    ) { uri ->
        if (uri != null) {
            vehicleImageUri = uri
            vehicleImageView.setImageURI(uri)
        }
    }

    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        setContentView(R.layout.activity_driver_verification)

        // Initialize views
        licenseNumberEditText = findViewById(R.id.license_number)
        vehicleTypeEditText = findViewById(R.id.vehicle_type)
        vehiclePlateEditText = findViewById(R.id.vehicle_plate)
        vehicleModelEditText = findViewById(R.id.vehicle_model)
        vehicleColorEditText = findViewById(R.id.vehicle_color)
        licenseImageView = findViewById(R.id.license_image)
        vehicleImageView = findViewById(R.id.vehicle_image)
        submitButton = findViewById(R.id.submit_button)

        licenseImageView.setOnClickListener {
            licenseImageLauncher.launch("image/*")
        }

        vehicleImageView.setOnClickListener {
            vehicleImageLauncher.launch("image/*")
        }

        submitButton.setOnClickListener {
            submitVerification()
        }
    }

    private fun submitVerification() {
        val licenseNumber = licenseNumberEditText.text.toString().trim()
        val vehicleType = vehicleTypeEditText.text.toString().trim()
        val vehiclePlate = vehiclePlateEditText.text.toString().trim()
        val vehicleModel = vehicleModelEditText.text.toString().trim()
        val vehicleColor = vehicleColorEditText.text.toString().trim()

        // Validate input
        if (licenseNumber.isEmpty() || vehicleType.isEmpty() || vehiclePlate.isEmpty() ||
            vehicleModel.isEmpty() || vehicleColor.isEmpty()) {
            Toast.makeText(this, "Please fill all fields", Toast.LENGTH_SHORT).show()
            return
        }

        val token = PreferenceManager.getToken() ?: return
        submitButton.isEnabled = false
        submitButton.text = "Submitting..."

        // Prepare multipart request
        val licenseNumberBody = licenseNumber.toRequestBody("text/plain".toMediaTypeOrNull())
        val vehicleTypeBody = vehicleType.toRequestBody("text/plain".toMediaTypeOrNull())
        val vehiclePlateBody = vehiclePlate.toRequestBody("text/plain".toMediaTypeOrNull())
        val vehicleModelBody = vehicleModel.toRequestBody("text/plain".toMediaTypeOrNull())
        val vehicleColorBody = vehicleColor.toRequestBody("text/plain".toMediaTypeOrNull())

        // Prepare image files
        var licenseImagePart: MultipartBody.Part? = null
        licenseImageUri?.let { uri ->
            val file = File(getRealPathFromUri(uri))
            licenseImagePart = MultipartBody.Part.createFormData(
                "license_image",
                file.name,
                file.asRequestBody("image/*".toMediaTypeOrNull())
            )
        }

        var vehicleImagePart: MultipartBody.Part? = null
        vehicleImageUri?.let { uri ->
            val file = File(getRealPathFromUri(uri))
            vehicleImagePart = MultipartBody.Part.createFormData(
                "vehicle_image",
                file.name,
                file.asRequestBody("image/*".toMediaTypeOrNull())
            )
        }

        // Make API call
        val apiService = RetrofitClient.getApiService()
        apiService.submitDriverVerification(
            token,
            licenseNumberBody,
            vehicleTypeBody,
            vehiclePlateBody,
            vehicleModelBody,
            vehicleColorBody,
            licenseImagePart,
            vehicleImagePart
        ).enqueue(object : Callback<com.example.ptoda.models.ApiResponse> {
            override fun onResponse(
                call: Call<com.example.ptoda.models.ApiResponse>,
                response: Response<com.example.ptoda.models.ApiResponse>
            ) {
                submitButton.isEnabled = true
                submitButton.text = "Submit"

                if (response.isSuccessful) {
                    Toast.makeText(this@DriverVerificationActivity, "Documents submitted successfully", Toast.LENGTH_SHORT).show()
                    startActivity(Intent(this@DriverVerificationActivity, DriverDashboardActivity::class.java))
                    finish()
                } else {
                    Toast.makeText(this@DriverVerificationActivity, "Submission failed", Toast.LENGTH_SHORT).show()
                }
            }

            override fun onFailure(call: Call<com.example.ptoda.models.ApiResponse>, t: Throwable) {
                submitButton.isEnabled = true
                submitButton.text = "Submit"
                Toast.makeText(this@DriverVerificationActivity, "Error: ${t.message}", Toast.LENGTH_LONG).show()
            }
        })
    }

    private fun getRealPathFromUri(uri: Uri): String {
        // Simple implementation - adjust based on your needs
        return uri.path ?: ""
    }
}
