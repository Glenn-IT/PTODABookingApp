import com.example.ptoda.network.RetrofitClient
import com.example.ptoda.utils.PreferenceManager
import retrofit2.Call
import retrofit2.Callback
import retrofit2.Response

class DriverDashboardActivity : AppCompatActivity() {

    private lateinit var nameTextView: TextView
    private lateinit var emailTextView: TextView
    private lateinit var phoneTextView: TextView
    private lateinit var vehicleTypeTextView: TextView
    private lateinit var vehiclePlateTextView: TextView
    private lateinit var vehicleImageView: ImageView

    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        setContentView(R.layout.activity_driver_dashboard)

        // Initialize views
        nameTextView = findViewById(R.id.driver_name)
        emailTextView = findViewById(R.id.driver_email)
        phoneTextView = findViewById(R.id.driver_phone)
        vehicleTypeTextView = findViewById(R.id.vehicle_type)
        vehiclePlateTextView = findViewById(R.id.vehicle_plate)
        vehicleImageView = findViewById(R.id.vehicle_image)

        // Load dashboard data
        loadDashboard()
    }

    private fun loadDashboard() {
        val token = PreferenceManager.getToken() ?: return

        val apiService = RetrofitClient.getApiService()
        apiService.getDriverDashboard(token).enqueue(object : Callback<DriverDashboardResponse> {
            override fun onResponse(
                call: Call<DriverDashboardResponse>,
                response: Response<DriverDashboardResponse>
            ) {
                if (response.isSuccessful) {
                    val dashboardResponse = response.body()
                    if (dashboardResponse != null) {
                        displayDriverInfo(dashboardResponse)
                    }
                } else {
                    Toast.makeText(
                        this@DriverDashboardActivity,
                        "Failed to load dashboard",
                        Toast.LENGTH_SHORT
                    ).show()
                }
            }

            override fun onFailure(call: Call<DriverDashboardResponse>, t: Throwable) {
                Toast.makeText(
                    this@DriverDashboardActivity,
                    "Error: ${t.message}",
                    Toast.LENGTH_LONG
                ).show()
            }
        })
    }

    private fun displayDriverInfo(response: DriverDashboardResponse) {
        val driverInfo = response.driver_info

        nameTextView.text = "Name: ${driverInfo.name}"
        emailTextView.text = "Email: ${driverInfo.email}"
        phoneTextView.text = "Phone: ${driverInfo.phone ?: "N/A"}"
        vehicleTypeTextView.text = "Vehicle: ${driverInfo.vehicle_type ?: "Not set"}"
        vehiclePlateTextView.text = "Plate: ${driverInfo.vehicle_plate ?: "Not set"}"

