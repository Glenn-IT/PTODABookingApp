## 8. Usage in MainActivity

```kotlin
package com.example.ptoda

import android.content.Intent
import android.os.Bundle
import androidx.appcompat.app.AppCompatActivity
import com.example.ptoda.ui.auth.LoginActivity
import com.example.ptoda.ui.driver.DriverDashboardActivity
import com.example.ptoda.ui.passenger.PassengerDashboardActivity
import com.example.ptoda.utils.PreferenceManager

class MainActivity : AppCompatActivity() {

    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)

        // Initialize PreferenceManager
        PreferenceManager.init(this)

        // Check if user is already logged in
        if (PreferenceManager.isLoggedIn()) {
            // Redirect to appropriate dashboard
            when (PreferenceManager.getUserType()) {
                "driver" -> {
                    startActivity(Intent(this, DriverDashboardActivity::class.java))
                }
                "passenger" -> {
                    startActivity(Intent(this, PassengerDashboardActivity::class.java))
                }
            }
        } else {
            // Redirect to login
            startActivity(Intent(this, LoginActivity::class.java))
        }

        finish()
    }
}
